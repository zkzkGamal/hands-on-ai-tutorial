{
    "datasets": 
        [
            {
                "name": "advertising",
                "path": "ml_fundamentals/chapter1/data/advertising.csv",
                "target": "Sales"
            },
            {
                "name": "Life Expectancy",
                "path": "ml_fundamentals/chapter1/data/Life Expectancy Data.csv",
                "target": ""
            },
            {
                "name":"student_data",
                "path": "ml_fundamentals/chapter1/data/student_data.csv",
                "target": ""
            }
        ],
    "models": {
        "Linear Regression": 
            {
                "algorithm": "LinearRegression",
                "parameters": {
                    "fit_intercept": true,
                    "n_jobs": -1
                }
            },
        "Random Forest Regression": {
            "algorithm": "RandomForestRegressor",
            "parameters": {
                "n_estimators": 100,
                "max_depth": 10,
                "n_jobs": -1
            }
        },
        "Support Vector Regression": {
            "algorithm": "SVR",
            "parameters": {
                "kernel": "rbf",
                "C": 1.0,
                "epsilon": 0.1,
                "degree": 3,
                "gamma": 0.1,
                "learning_rate": 0.001,
                "epochs": 50
            }
        }
    },
    "metrics": {
        "Mean Squared Error": "mse",
        "R-squared": "r2"
    },
    "splits": {
        "train_test_split": {
            "test_size": 0.2,
            "random_state": 42
        },
        "kfold": {
            "n_splits": 5,
            "shuffle": true,
            "random_state": 42
        }
    },
    "reports": {
        "csv": {
            "dir": "ml_fundamentals/chapter1/results",
            "name": "regression_report"
        },
        "json": {
            "dir": "ml_fundamentals/chapter1/results",
            "name": "regression_report"
        }
    },
    "saved_models": {
        "dir": "ml_fundamentals/chapter1/models"
    }
}